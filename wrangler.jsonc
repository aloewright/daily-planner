{
  "name": "daily-planner",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "daily-planner-db",
      "database_id": "3afbe37d-947e-4f92-bbd9-db3be5065ea8"
    }
  ]
}
