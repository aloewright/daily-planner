{
  "name": "daily-planner",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "BETTER_AUTH_URL": "https://alex.coffee"
  }
  // To enable public share links for /highlights, create an R2 bucket and add:
  // "r2_buckets": [{ "binding": "HIGHLIGHTS_BUCKET", "bucket_name": "daily-planner-highlights" }]
}
